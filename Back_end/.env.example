# MySQL 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=asset_management

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 跨域配置（前端地址，多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 认证配置
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 默认初始化账号（首次启动时如不存在则创建）
DEFAULT_ADMIN_USERNAME=DAIL
DEFAULT_ADMIN_PASSWORD=DAIL2026

# 资产编号配置：组织码（公司简称），用于资产编号前缀，例如 DG-IT-2026-000123-X
ORG_CODE=DG

# 二维码内容指向的前端访问地址前缀（手机扫码后会打开此地址）
# 本地仅电脑访问可用 http://localhost:5173
# 手机扫码请改为电脑的局域网 IP，例如 http://192.168.1.10:5173
PUBLIC_BASE_URL=http://localhost:5173

# ============ 腾讯云 COS 对象存储 ============
# 在 https://console.cloud.tencent.com/cam/capi 获取
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_REGION=ap-chengdu
COS_BUCKET=your-bucket-1234567890
COS_DOMAIN=
COS_PREFIX=assets
UPLOAD_MAX_SIZE_MB=50

# ============ 阿里云百炼 DashScope（大模型 API） ============
# 控制台获取 API Key：https://bailian.console.aliyun.com/?apiKey=1
# 留空则 AI 智能补全 / 字段映射会回退到规则兜底
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# 单次 Excel 导入最大行数（防止大文件压垮服务）
IMPORT_MAX_ROWS=500
