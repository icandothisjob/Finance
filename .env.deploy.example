# =========================================================
# docker-compose 部署环境变量模板
# 用法：复制为 .env，按需修改后执行 docker compose up -d
#   cp .env.deploy.example .env
# =========================================================

# 对外暴露的 Web 端口（浏览器访问用）
WEB_PORT=80

# MySQL（容器内部，仅作为 root 密码与数据库名）
MYSQL_PASSWORD=ChangeMe_StrongPwd_123
MYSQL_DATABASE=asset_management

# 跨域：前端和后端走同一个域名时，可填 http://服务器IP；多个用逗号分隔
CORS_ORIGINS=http://localhost,http://127.0.0.1

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string-at-least-32-chars

# 默认超级管理员（首次启动若不存在则创建）
DEFAULT_ADMIN_USERNAME=DAIL
DEFAULT_ADMIN_PASSWORD=DAIL2026

# 资产编号前缀
ORG_CODE=DG

# 二维码扫码后跳转的前端访问地址（手机要能访问到，即服务器公网 IP / 域名）
PUBLIC_BASE_URL=http://your-server-ip

# ============ 腾讯云 COS 对象存储 ============
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_REGION=ap-chengdu
COS_BUCKET=your-bucket-1234567890
COS_DOMAIN=
COS_PREFIX=assets
UPLOAD_MAX_SIZE_MB=50

# ============ 阿里云百炼 DashScope（大模型 API） ============
# 控制台获取 API Key：https://bailian.console.aliyun.com/?apiKey=1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
IMPORT_MAX_ROWS=500
